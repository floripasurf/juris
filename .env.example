# === Database ===
DATABASE_URL=postgresql+asyncpg://juris:juris_dev@localhost:5432/juris
DATABASE_URL_SYNC=postgresql+psycopg://juris:juris_dev@localhost:5432/juris

# === Qdrant ===
QDRANT_URL=http://localhost:6333

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Object Storage (local filesystem for v1) ===
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage

# === LLM — Cloud ===
ANTHROPIC_API_KEY=sk-ant-...

# === LLM — Local ===
OLLAMA_URL=http://localhost:11434

# === ICP-Brasil Certificate ===
# Path to the .pfx/.p12 file (A1) or PKCS#11 module path (A3)
CERT_PATH=
CERT_PASSWORD=
# CPF do advogado (used as idConsultante for MNI)
ADVOGADO_CPF=
# A3 hardware token (mTLS tribunals like TJMG): PKCS#11 module path.
# macOS SafeNet eToken default below; override for other tokens/OSes.
PKCS11_MODULE=/usr/local/lib/libeTPkcs11.dylib
# Optional: token PIN. Leave blank to be prompted (never logged).
# WARNING: wrong PINs can lock an A3 token — prefer the interactive prompt.
TOKEN_PIN=

# === macOS: WeasyPrint native libs ===
# Homebrew installs gobject/pango under /opt/homebrew/lib (Apple Silicon)
# or /usr/local/lib (Intel). WeasyPrint needs this to find them.
# On Linux this is not needed (apt packages put libs in the default path).
# DYLD_LIBRARY_PATH=/opt/homebrew/lib:/usr/local/lib

# === DataJud ===
DATAJUD_API_KEY=

# === General ===
# dev|prod. Em prod, combine com JURIS_REQUIRE_TENANTS=1.
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
# Raiz local de dados/artefatos do piloto. Em prod, use diretório owner-only.
JURIS_HOME=
# Saída de runs/artefatos quando aplicável; mantenha fora do web root público.
JURIS_OUT_ROOT=

# === Web/API runtime ===
# Per-API-key burst limit. Set to 0 only behind an external limiter.
JURIS_API_RATE_LIMIT_PER_MINUTE=120
# Separate per-API-key limit for expensive operations: demo, corpus search/reingest,
# filing dry-run and filing submit.
JURIS_API_EXPENSIVE_RATE_LIMIT_PER_MINUTE=12
# Per-tenant/IP limit for the remote-agent WebSocket relay handshake.
JURIS_WS_AGENT_RELAY_RATE_LIMIT_PER_MINUTE=30
# Optional shared limiter for multi-worker SaaS deployments.
JURIS_RATE_LIMIT_REDIS_URL=
# Em prod exposto, falha fechado se o Redis do rate limit estiver indisponível.
JURIS_RATE_LIMIT_FAIL_CLOSED=false
# Confia em CF-Connecting-IP/X-Forwarded-For para buckets por IP. Ligue só atrás de proxy confiável.
JURIS_TRUSTED_PROXY=false
# Declara que há rate limit externo no proxy/WAF quando não usar Redis multi-worker.
JURIS_RATE_LIMIT_PROXY=false
# Maximum seconds for a connect/sync background job before it is marked failed.
JURIS_CONNECT_TIMEOUT_SECONDS=900
# Enable only after TST inteiro-teor ToS is approved in data/tos_compliance_log.md.
JURIS_TST_INTEIRO_TEOR_ENABLED=false
# Fornecedor preferido para IA no navegador do advogado: claude|chatgpt|blank.
JURIS_AI_BROWSER_PROVIDER=
# Em prod, rejeita URLs de backend ainda no default localhost de desenvolvimento.
JURIS_STRICT_PROD_URLS=false

# === Multi-tenant / trial ===
# Obrigatório em prod exposto: sem tenants configurados, o app falha fechado.
JURIS_REQUIRE_TENANTS=false
# JSON de tenants/API keys hashadas. Deve ser 0600.
JURIS_TENANTS_FILE=config/tenants.json
# JSON de bindings dos agentes remotos por tenant. Deve ser 0600.
JURIS_AGENTS_FILE=config/agents.json
# Duração do teste anônimo, limitado pelo código.
JURIS_TRIAL_DAYS=30
# Teto de trials ativos para evitar exaustão de storage.
JURIS_TRIAL_MAX_ACTIVE=500
# Teto diário de novos trials anônimos.
JURIS_TRIAL_MAX_NEW_PER_DAY=100
# URL pública do relay entregue ao agente local.
JURIS_TRIAL_RELAY_URL=wss://causia.com.br/ws/agent-relay

# === Remote local-agent relay ===
# local|remote. Use local em dev; para piloto hospedado/split-trust, use remote.
JURIS_AGENT_MODE=local
# Broker Redis para relay em múltiplos workers. Alternativa: sticky routing explícito.
JURIS_RELAY_BROKER=
# Assertiva operacional: load balancer garante afinidade tenant/agente.
JURIS_RELAY_STICKY=false
# URL/token globais legados do agente local; não use com JURIS_REQUIRE_TENANTS=1.
JURIS_LOCAL_AGENT_URL=
JURIS_LOCAL_AGENT_TOKEN=

# === Agent distribution / update ===
# Diretório servido por /api/agent/latest com agent-latest.json assinado.
JURIS_AGENT_DIST_DIR=
# Manifesto de atualização consultado pelo agente.
JURIS_AGENT_UPDATE_URL=https://causia.com.br/api/agent/latest
# Chave pública Ed25519 do manifesto de atualização.
JURIS_AGENT_UPDATE_PUBKEY=

# === Repertory / embeddings ===
# Caminho do SQLite/FTS5 do repertório local.
JURIS_REPERTORY_PATH=
# Em prod, falha fechado se o modelo de embeddings não estiver disponível.
JURIS_REQUIRE_EMBEDDINGS=false
# Preflight mínimo de profundidade do corpus.
JURIS_MIN_REPERTORY_CHUNKS=0
JURIS_MIN_REPERTORY_SOURCE_TYPES=
JURIS_MIN_FULL_TEXT_CHUNKS=0

# === Audit integrity ===
# Required in ENVIRONMENT=prod. Used to sign audit.jsonl head/tail anchors.
JURIS_AUDIT_HMAC_KEY=

# === Operational backup ===
# Optional destination for `juris backup create`.
# Default: ${JURIS_HOME:-~/.juris}/backups
JURIS_BACKUP_DIR=

# === MNI mTLS / OpenSSL ===
# Optional. Leave blank to use OpenSSL's default CA store. Set only when the
# token-backed MNI path needs an explicit server trust bundle.
MNI_SERVER_CA_PEM_PATH=

# Billing (Fase A — Pix Automático): URL da recorrência criada no seu PSP
# (Efí/Asaas/Mercado Pago/banco PJ com Pix Automático p/ recebedor).
# Quando definida, o modal Contratar mostra "Assinar com Pix Automático";
# vazia = WhatsApp como caminho. Ativação pós-pagamento: juris tenant promote <id>.
JURIS_BILLING_PIX_LINK=
