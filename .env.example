# === Database ===
DATABASE_URL=postgresql+asyncpg://juris:juris_dev@localhost:5432/juris
DATABASE_URL_SYNC=postgresql+psycopg://juris:juris_dev@localhost:5432/juris

# === Qdrant ===
QDRANT_URL=http://localhost:6333

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Object Storage (local filesystem for v1) ===
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage

# === LLM — Cloud ===
ANTHROPIC_API_KEY=sk-ant-...

# === LLM — Local ===
OLLAMA_URL=http://localhost:11434

# === ICP-Brasil Certificate ===
# Path to the .pfx/.p12 file (A1) or PKCS#11 module path (A3)
CERT_PATH=
CERT_PASSWORD=
# CPF do advogado (used as idConsultante for MNI)
ADVOGADO_CPF=
# A3 hardware token (mTLS tribunals like TJMG): PKCS#11 module path.
# macOS SafeNet eToken default below; override for other tokens/OSes.
PKCS11_MODULE=/usr/local/lib/libeTPkcs11.dylib
# Optional: token PIN. Leave blank to be prompted (never logged).
# WARNING: wrong PINs can lock an A3 token — prefer the interactive prompt.
TOKEN_PIN=

# === macOS: WeasyPrint native libs ===
# Homebrew installs gobject/pango under /opt/homebrew/lib (Apple Silicon)
# or /usr/local/lib (Intel). WeasyPrint needs this to find them.
# On Linux this is not needed (apt packages put libs in the default path).
# DYLD_LIBRARY_PATH=/opt/homebrew/lib:/usr/local/lib

# === DataJud ===
DATAJUD_API_KEY=

# === General ===
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# === Web/API runtime ===
# Per-API-key burst limit. Set to 0 only behind an external limiter.
JURIS_API_RATE_LIMIT_PER_MINUTE=120
# Separate per-API-key limit for expensive operations: demo, corpus search/reingest,
# filing dry-run and filing submit.
JURIS_API_EXPENSIVE_RATE_LIMIT_PER_MINUTE=12
# Per-tenant/IP limit for the remote-agent WebSocket relay handshake.
JURIS_WS_AGENT_RELAY_RATE_LIMIT_PER_MINUTE=30
# Optional shared limiter for multi-worker SaaS deployments.
JURIS_RATE_LIMIT_REDIS_URL=
# Maximum seconds for a connect/sync background job before it is marked failed.
JURIS_CONNECT_TIMEOUT_SECONDS=900
# Enable only after TST inteiro-teor ToS is approved in data/tos_compliance_log.md.
JURIS_TST_INTEIRO_TEOR_ENABLED=false

# === Audit integrity ===
# Required in ENVIRONMENT=prod. Used to sign audit.jsonl head/tail anchors.
JURIS_AUDIT_HMAC_KEY=

# === Operational backup ===
# Optional destination for `juris backup create`.
# Default: ${JURIS_HOME:-~/.juris}/backups
JURIS_BACKUP_DIR=

# === MNI mTLS / OpenSSL ===
# Optional. Leave blank to use OpenSSL's default CA store. Set only when the
# token-backed MNI path needs an explicit server trust bundle.
MNI_SERVER_CA_PEM_PATH=
