<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd template for the juris local agent (the token holder, ADR-0015).
  Runs `juris agent serve` (loopback-only) at login. Copy to
  ~/Library/LaunchAgents/com.juris.agent.plist, fill in the REPLACE_* values,
  then: launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.juris.agent.plist
  Secrets live here on the LAWYER's machine — never on the orchestrator.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.juris.agent</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Use the venv entrypoint directly; launchd wrappers can hang silently. -->
    <string>REPLACE_WITH_PATH_TO/juris/.venv/bin/juris</string>
    <string>agent</string>
    <string>serve</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8765</string>
  </array>

  <key>WorkingDirectory</key>
  <string>REPLACE_WITH_PATH_TO/juris</string>

  <key>EnvironmentVariables</key>
  <dict>
    <!-- pairing: same value as the tenant token in JURIS_AGENTS_FILE -->
    <key>JURIS_AGENT_TOKEN</key>
    <string>REPLACE_WITH_PAIRING_TOKEN</string>
    <!-- Optional on the lawyer's machine only. If omitted, token operations fail
         closed until the local environment/keychain supplies the values. -->
    <key>JURIS_AGENT_CPF</key>
    <string>REPLACE_OPTIONAL_LAWYER_CPF</string>
    <key>JURIS_AGENT_SENHA</key>
    <string>REPLACE_OPTIONAL_PJE_PASSWORD</string>
    <key>JURIS_AGENT_PIN</key>
    <string>REPLACE_OPTIONAL_A3_PIN</string>
    <!-- path to the A3 token's PKCS#11 module -->
    <key>JURIS_PKCS11_MODULE</key>
    <string>/Library/Frameworks/eToken.framework/Versions/A/libeToken.dylib</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <!-- Owner-only log dir (chmod 700); NOT /tmp (world-readable). -->
  <key>StandardOutPath</key>
  <string>REPLACE_WITH_PATH_TO/logs/agent.log</string>
  <key>StandardErrorPath</key>
  <string>REPLACE_WITH_PATH_TO/logs/agent.err</string>
</dict>
</plist>
