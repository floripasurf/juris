<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd template for the juris local agent (the token holder, ADR-0015).
  Runs `juris agent serve` (loopback-only) at login. Copy to
  ~/Library/LaunchAgents/com.juris.agent.plist, fill in the REPLACE_* values,
  then: launchctl load ~/Library/LaunchAgents/com.juris.agent.plist
  Secrets live here on the LAWYER's machine — never on the orchestrator.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.juris.agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/uv</string>
    <string>run</string>
    <string>juris</string>
    <string>agent</string>
    <string>serve</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8765</string>
  </array>

  <key>WorkingDirectory</key>
  <string>REPLACE_WITH_PATH_TO/juris</string>

  <key>EnvironmentVariables</key>
  <dict>
    <!-- pairing: same value as JURIS_LOCAL_AGENT_TOKEN on the orchestrator -->
    <key>JURIS_AGENT_TOKEN</key>
    <string>REPLACE_WITH_PAIRING_TOKEN</string>
    <!-- the lawyer's own secrets — resolved here, never sent to the cloud -->
    <key>JURIS_AGENT_CPF</key>
    <string>REPLACE</string>
    <key>JURIS_AGENT_SENHA</key>
    <string>REPLACE</string>
    <key>JURIS_AGENT_PIN</key>
    <string>REPLACE</string>
    <!-- path to the A3 token's PKCS#11 module -->
    <key>JURIS_PKCS11_MODULE</key>
    <string>/Library/Frameworks/eToken.framework/Versions/A/libeToken.dylib</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/juris-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/juris-agent.err</string>
</dict>
</plist>
