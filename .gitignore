# ============================================
# Local-only engine internals — kept OUT of this repo by design
# ============================================
# NOTE: most former "engine" files (analyzer, drafter, retrieval service,
# prompts, prazo, review, defesas, corpus, ingestion) are now TRACKED and
# published — their old "DO NOT PUBLISH" entries were obsolete and were removed
# (they only produced misleading `git status` and forced `git add -f`). Only
# genuinely-local pieces remain below: the proprietary composite ranker and the
# local-only engine tests that mirror it. Bulk
# corpus DATA (Decisoes/, Petiçoes/, ...) is ignored separately above.

# Proprietary bits that stay local (untracked by design)
src/juris/repertory/retrieval/ranking.py

# Local-only engine tests (mirror the local internals; not in public CI).
# The public EstrategiaAgent test (tests/unit/agents/test_estrategia.py) IS tracked.
tests/unit/test_analyzer.py
tests/unit/test_defesa_analyzer.py
tests/unit/test_embeddings.py
tests/unit/test_chunking.py
tests/unit/test_hybrid_retrieval.py
